    ]
  },
  "dependencies": {
    "better-sqlite3": "11.9.1",
    "express": "4.21.2",
    "express-rate-limit": "8.5.1"
  },
  "devDependencies": {
    "jest": "29.7.0",
    "supertest": "7.1.0"
  }
}
