{
  "name": "scenario-02-api-latency-n-plus-one",
  "version": "1.0.0",
  "description": "Scenario 02: API Latency caused by N+1 Database Queries",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "test": "jest --forceExit"
